<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes">
    <title>🍽️ RISTORANTE VIRTÙ | Friesenberger Klasse</title>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
        }
        body {
            background: #1a1e1b;
            font-family: 'Segoe UI', 'Roboto', system-ui, sans-serif;
            padding: 16px 12px 40px;
            color: #f0eadb;
        }
        .page {
            max-width: 1000px;
            margin: 0 auto;
            background: #2c312b;
            border-radius: 36px 36px 28px 28px;
            padding: 22px 18px 32px;
            box-shadow: 0 12px 28px rgba(0,0,0,0.6);
            border: 1px solid #4e5b4c;
        }
        h1 {
            font-size: 2.1rem;
            font-weight: 600;
            letter-spacing: 1px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            border-bottom: 3px solid #b89b6b;
            padding-bottom: 16px;
            margin-bottom: 20px;
            color: #f3e7d3;
        }
        h1 small {
            font-size: 1.1rem;
            font-weight: 400;
            background: #3f4a3c;
            padding: 6px 16px;
            border-radius: 50px;
            color: #e3d6bf;
            border: 1px solid #7e8d76;
        }
        h2 {
            font-size: 1.8rem;
            font-weight: 500;
            margin: 30px 0 16px 0;
            color: #dbc9a8;
            border-left: 12px solid #b89b6b;
            padding-left: 18px;
        }
        h3 {
            font-weight: 600;
            font-size: 1.3rem;
            margin: 24px 0 12px 0;
            color: #d4c2a2;
        }
        .header-bar {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 16px;
        }
        .btn-group {
            display: flex;
            gap: 12px;
        }
        .btn {
            background: #3e493b;
            border: 1px solid #7b8b74;
            color: #f2e5d0;
            padding: 10px 20px;
            border-radius: 60px;
            font-weight: 600;
            font-size: 1rem;
            cursor: pointer;
            transition: all 0.15s;
            box-shadow: 0 2px 6px rgba(0,0,0,0.3);
        }
        .btn:hover {
            background: #576b51;
            border-color: #b89b6b;
        }
        .btn.admin {
            background: #6d5c3e;
            border-color: #dbbc87;
            color: #fff6e5;
        }
        .admin-panel {
            background: #232b22;
            padding: 16px 20px;
            border-radius: 30px;
            margin: 20px 0 16px;
            border: 1px dashed #b89b6b;
        }
        .hidden {
            display: none !important;
        }
        input, select {
            background: #1e241c;
            border: 1px solid #8a7b60;
            color: #f2e5d0;
            padding: 8px 14px;
            border-radius: 40px;
            font-size: 1rem;
            margin-right: 10px;
        }
        .team-badge {
            display: inline-block;
            background: #1f2a1e;
            padding: 6px 16px;
            border-radius: 32px;
            font-weight: 600;
            border: 1px solid #7e8d76;
            margin: 6px 6px 0 0;
        }
        .match-card {
            background: #232b20;
            border-radius: 28px;
            padding: 18px 20px;
            margin-bottom: 22px;
            border: 1px solid #5f7256;
            box-shadow: inset 0 0 0 1px #3e4e38;
        }
        .match-header {
            display: flex;
            justify-content: space-between;
            color: #cbbda0;
            font-weight: 500;
            margin-bottom: 10px;
            border-bottom: 1px dashed #7e8d76;
            padding-bottom: 8px;
        }
        .match-teams {
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 10px;
        }
        .team {
            font-weight: 700;
            font-size: 1.3rem;
        }
        .score {
            font-family: 'Courier New', monospace;
            font-size: 2rem;
            font-weight: 700;
            background: #10170e;
            padding: 6px 18px;
            border-radius: 48px;
            letter-spacing: 6px;
            border: 1px solid #b89b6b;
            color: #efe1c6;
        }
        .winner-icon {
            margin-left: 6px;
            font-size: 1.6rem;
        }
        table {
            width: 100%;
            border-collapse: collapse;
            background: #1e261c;
            border-radius: 24px;
            overflow: hidden;
            box-shadow: 0 6px 12px rgba(0,0,0,0.5);
            margin: 25px 0;
        }
        th {
            background: #3c4d36;
            color: #f3e9d9;
            font-weight: 600;
            padding: 14px 8px;
            text-align: left;
        }
        td {
            padding: 14px 8px;
            border-bottom: 1px solid #4b5e45;
        }
        .ranking-1 { background: #b89b6b20; border-left: 8px solid #d4af37; }
        .footer-note {
            margin-top: 30px;
            text-align: right;
            font-size: 0.9rem;
            color: #a7b39b;
            border-top: 1px solid #4a5b44;
            padding-top: 16px;
        }
        .flag {
            font-size: 1.2rem;
            margin-right: 4px;
        }
        .edit-icon {
            opacity: 0.7;
            font-size: 1.2rem;
            margin-left: 8px;
            cursor: pointer;
        }
        .inline-edit {
            display: inline-block;
        }
    </style>
</head>
<body>
<div class="page">
    <div class="header-bar">
        <h1 style="border-bottom: none; padding-bottom: 0; margin-bottom: 0;">🍝 RISTORANTE VIRTÙ <small>Friesenberger Klasse</small></h1>
        <div class="btn-group">
            <button class="btn" id="toggleAdminBtn">🔓 Admin</button>
        </div>
    </div>
    <p style="margin-bottom: 20px; font-style: italic;">Padel Turnier 2026 · Friesenberger Klasse · Teams A–F</p>

    <!-- Admin Panel (versteckt) -->
    <div id="adminPanel" class="admin-panel hidden">
        <div style="display: flex; gap: 16px; flex-wrap: wrap; align-items: center;">
            <span style="font-weight: 700;">✏️ Bearbeitungsmodus aktiv</span>
            <input type="password" id="adminPass" placeholder="Passwort" value="">
            <button class="btn" id="verifyPassBtn">Freischalten</button>
            <button class="btn" id="saveAllBtn" style="background:#7b6b4b;">💾 Alle Änderungen speichern</button>
        </div>
        <p style="margin-top: 12px; font-size: 0.9rem;">Nach Freischaltung können Scores per Klick geändert werden. Speichern nicht vergessen!</p>
        <p id="adminStatus" style="color: #c7b28b;"></p>
    </div>

    <!-- Teams Übersicht -->
    <h2>👥 Teams</h2>
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(170px,1fr)); gap: 8px; margin-bottom: 30px;">
        <div class="team-badge"><strong>Team A</strong> 🇩🇪 Marjan Dujak · 🇧🇪 Ilmi Brati</div>
        <div class="team-badge"><strong>Team B</strong> 🇵🇸 Artan Pnishi · 🇦🇺 Arben Pnishi</div>
        <div class="team-badge"><strong>Team C</strong> 🇨🇴 Driton Zemaj · 🇧🇷 Arbnon Brati</div>
        <div class="team-badge"><strong>Team D</strong> 🇲🇾 Limi Maxharraj · 🇦🇷 Rocco Siffredi</div>
        <div class="team-badge"><strong>Team E</strong> 🇮🇶 Cipriano Gionni · 🇦🇷 Liridon Ajvazi</div>
        <div class="team-badge"><strong>Team F</strong> 🇧🇹 Guxim Berisha · 🇫🇷 Durim Berisha</div>
    </div>

    <!-- WOCHEN 1-5: Matches dynamisch per JS generiert -->
    <h2>📅 Spielplan & Resultate</h2>
    <div id="matchesContainer"></div>

    <!-- Rangliste -->
    <h2>🏆 Rangliste – Top 4 ins Halbfinale</h2>
    <table id="rankingTable">
        <thead><tr><th>Platz</th><th>Team</th><th>Punkte</th></tr></thead>
        <tbody id="rankingBody"></tbody>
    </table>

    <!-- Punktevergabe -->
    <div style="background: #1e2a1b; border-radius: 24px; padding: 18px; margin: 30px 0;">
        <h3 style="margin-top: 0;">📊 Punktevergabe pro Match</h3>
        <p>3:0 Sieg → 3 Punkte · 2:1 Sieg → 2 Punkte · 1:2 Niederlage → 1 Punkt · 0:3 Niederlage → 0 Punkte</p>
        <p><small>Jeder gewonnene Satz zählt 1 Punkt für das Team.</small></p>
    </div>

    <!-- Halbfinale / Finale -->
    <h2>🥇 Halbfinale & Finale</h2>
    <p><em>Termine folgen – Top 4 nach Woche 5</em></p>
    <div style="background: #1d261a; border-radius: 28px; padding: 20px;">
        <p>??.04.2026 – Halbfinale 1: Platz 1 vs Platz 4</p>
        <p>??.04.2026 – Halbfinale 2: Platz 2 vs Platz 3</p>
        <p>??.04.2026 – Spiel um Platz 3</p>
        <p>??.04.2026 – Finale</p>
    </div>

    <div class="footer-note">
        ristorante-virtu.ch/friesenberger · nur du bearbeitest
    </div>
</div>

<script>
    (function(){
        "use strict";

        // ---------- TEAMS DEFINITION ----------
        const TEAMS = ["A","B","C","D","E","F"];
        const teamNames = {
            "A": "🇩🇪 Dujak · 🇧🇪 Brati I.",
            "B": "🇵🇪 Pnishi A. · 🇵🇪 Pnishi Ar.",
            "C": "🇩🇪 Zemaj · 🇧🇷 Brati Ar.",
            "D": "🇲🇾 Maxharraj · 🇸🇮 Siffredi",
            "E": "🇮🇹 Cipriano · 🇮🇹 Ajvazi",
            "F": "🇫🇷 Berisha G. · 🇫🇷 Berisha D."
        };

        // ---------- MATCH DATEN (aus Screenshots) ----------
        // Struktur: matches[week][index] = { team1, team2, score1, score2, winner, date, location, sets (array) }
        let matchesData = [
            // Woche 1 (Index 0)
            [
                { team1:"A", team2:"F", sets:[[6,3],[6,0],[7,6]], winner:"A", date:"Do 26.03.2026 21:00", location:"Yakinarena" },
                { team1:"B", team2:"E", sets:[[6,2],[6,3],[6,0]], winner:"B", date:"Do 26.03.2026 21:30", location:"Yakinarena" },
                { team1:"C", team2:"D", sets:[[7,5],[7,5],[6,3]], winner:"C", date:"Do 26.03.2026 21:30", location:"Yakinarena" }
            ],
            // Woche 2
            [
                { team1:"A", team2:"E", sets:[[6,3],[2,6],[1,6]], winner:"E", date:"Mo 30.03.2026 21:00", location:"Unipadel Rümlang" },
                { team1:"F", team2:"D", sets:[[0,6],[1,6],[3,6]], winner:"D", date:"Di 31.03.2026 21:00", location:"Unipadel Rümlang" },
                { team1:"B", team2:"C", sets:[[5,7],[5,3],[]], winner:null, date:"Mo 30.03.2026 21:00", location:"Unipadel Rümlang", incomplete: true } // unvollständig
            ],
            // Woche 3
            [
                { team1:"A", team2:"D", sets:[[4,6],[7,5],[6,2]], winner:"A", date:"Mi 08.04.2026 21:00", location:"Yakinarena" },
                { team1:"E", team2:"C", sets:[[0,6],[0,6],[3,6]], winner:"C", date:"Do 16.04.2026", location:"Rümlang" },
                { team1:"F", team2:"B", sets:[[0,6],[1,6],[2,6]], winner:"B", date:"Mi 08.04.2026 21:00", location:"Yakinarena" }
            ],
            // Woche 4
            [
                { team1:"A", team2:"C", sets:[[2,6],[4,6],[2,6]], winner:"C", date:"Di 14.04.2026", location:"Neighborhood Spreitenbach" },
                { team1:"D", team2:"B", sets:[[4,6],[6,4],[2,6]], winner:"B", date:"Do 16.04.2026", location:"Unipadel Rümlang" },
                { team1:"E", team2:"F", sets:[[],[],[]], winner:null, date:"??.04.2026", location:"", incomplete: true }
            ],
            // Woche 5
            [
                { team1:"A", team2:"B", sets:[[1,6],[5,7],[2,6]], winner:"B", date:"18.03.2026 21:30", location:"PDL Zürich" },
                { team1:"C", team2:"F", sets:[[],[],[]], winner:null, date:"??.04.2026", location:"" },
                { team1:"D", team2:"E", sets:[[],[],[]], winner:null, date:"??.04.2026", location:"" }
            ]
        ];

        // Korrektur: Match B-C Woche2 Satz3 unklar, auf unentschieden setzen? Original zeigt 5-5 ↑, 7-3, letzter Satz fehlt. Wir setzen keinen Winner.
        // Für Ranking: Gewertet wird nach gespielten Sätzen.

        // Admin state
        let isAdmin = false;
        let passwordOK = false;
        const ADMIN_PASSWORD = "friesenberger2026";  // ⚠️ Passwort nach Wunsch änderbar

        // DOM
        const container = document.getElementById('matchesContainer');
        const rankingBody = document.getElementById('rankingBody');
        const adminPanel = document.getElementById('adminPanel');
        const toggleBtn = document.getElementById('toggleAdminBtn');
        const passInput = document.getElementById('adminPass');
        const verifyBtn = document.getElementById('verifyPassBtn');
        const saveAllBtn = document.getElementById('saveAllBtn');
        const adminStatus = document.getElementById('adminStatus');

        // ---------- HILFSFUNKTIONEN ----------
        function calculatePoints() {
            let points = { A:0, B:0, C:0, D:0, E:0, F:0 };
            matchesData.flat().forEach(m => {
                if (!m.sets || m.sets.length<3) return;
                const t1 = m.team1, t2 = m.team2;
                let t1w = 0, t2w = 0;
                m.sets.forEach(s => {
                    if(s.length===2 && typeof s[0]==='number' && typeof s[1]==='number') {
                        if(s[0] > s[1]) t1w++;
                        else if(s[1] > s[0]) t2w++;
                    }
                });
                // Punktevergabe
                if(t1w === 3) { points[t1] += 3; }
                else if(t2w === 3) { points[t2] += 3; }
                else if(t1w === 2 && t2w === 1) { points[t1] += 2; points[t2] += 1; }
                else if(t2w === 2 && t1w === 1) { points[t2] += 2; points[t1] += 1; }
                // bei unvollständig keine Punkte
            });
            return points;
        }

        function renderRanking() {
            const pts = calculatePoints();
            const sorted = Object.entries(pts).sort((a,b) => b[1] - a[1]);
            rankingBody.innerHTML = '';
            sorted.forEach(([team, p], idx) => {
                const tr = document.createElement('tr');
                if(idx<4) tr.className = 'ranking-1';
                tr.innerHTML = `<td>${idx+1}</td><td><strong>Team ${team}</strong> ${teamNames[team]}</td><td>${p}</td>`;
                rankingBody.appendChild(tr);
            });
        }

        function formatSets(sets) {
            return sets.map(s => {
                if(!s || s.length<2) return '-';
                if(typeof s[0]!=='number') return '-';
                return `${s[0]}:${s[1]}`;
            }).join(' ');
        }

        function renderMatches() {
            if(!container) return;
            let html = '';
            for(let w=0; w<matchesData.length; w++) {
                const weekMatches = matchesData[w];
                html += `<h3>📆 Woche ${w+1} – ${w===0?'23.–29.03.': w===1?'30.03.–05.04.': w===2?'06.–12.04.': w===3?'13.–19.04.':'20.–26.04.2026'}</h3>`;
                weekMatches.forEach((m, idx) => {
                    const t1 = m.team1, t2 = m.team2;
                    const setsStr = formatSets(m.sets);
                    const winner = m.winner;
                    const dateLoc = `${m.date} ${m.location}`.trim();
                    html += `<div class="match-card" data-week="${w}" data-index="${idx}">`;
                    html += `<div class="match-header"><span>${dateLoc}</span> ${winner ? '🏆' : ''}</div>`;
                    html += `<div class="match-teams">`;
                    html += `<span class="team">Team ${t1} ${teamNames[t1].substring(0,20)}</span>`;
                    html += `<span class="score" id="score-${w}-${idx}">${setsStr}</span>`;
                    html += `<span class="team">Team ${t2} ${teamNames[t2].substring(0,20)}</span>`;
                    html += `</div>`;
                    if(isAdmin && passwordOK) {
                        html += `<div style="margin-top:10px;"><button class="btn" data-edit="${w}-${idx}">✎ Score ändern</button></div>`;
                    }
                    html += `</div>`;
                });
            }
            container.innerHTML = html;

            if(isAdmin && passwordOK) {
                document.querySelectorAll('[data-edit]').forEach(btn => {
                    btn.addEventListener('click', (e) => {
                        const [w,i] = btn.dataset.edit.split('-').map(Number);
                        editMatchScore(w,i);
                    });
                });
            }
        }

        function editMatchScore(week, index) {
            const match = matchesData[week][index];
            let newSets = prompt(`Neue Satzergebnisse (Format: 6 3, 6 2, 7 5) für Team ${match.team1} vs ${match.team2}`, match.sets.map(s=>s.join(' ')).join(', '));
            if(!newSets) return;
            try {
                let parts = newSets.split(',').map(p => p.trim().split(/\s+/).map(Number));
                if(parts.length===3 && parts.every(a=>a.length===2 && !isNaN(a[0])&&!isNaN(a[1]))) {
                    match.sets = parts;
                    // winner automatisch bestimmen
                    let t1w=0, t2w=0;
                    parts.forEach(s => { if(s[0]>s[1]) t1w++; else if(s[1]>s[0]) t2w++; });
                    match.winner = t1w > t2w ? match.team1 : (t2w > t1w ? match.team2 : null);
                    renderMatches();
                    renderRanking();
                } else alert('Falsches Format');
            } catch(e) { alert('Fehler'); }
        }

        function checkPassword() {
            if(passInput.value === ADMIN_PASSWORD) {
                passwordOK = true;
                adminStatus.textContent = '✅ Freigeschaltet – du kannst Scores ändern.';
                renderMatches();
            } else {
                passwordOK = false;
                adminStatus.textContent = '❌ Falsches Passwort';
            }
        }

        function saveToLocal() {
            localStorage.setItem('friesenbergerMatches', JSON.stringify(matchesData));
            alert('Gespeichert! (lokal im Browser)');
        }

        function loadFromLocal() {
            const saved = localStorage.getItem('friesenbergerMatches');
            if(saved) {
                try {
                    matchesData = JSON.parse(saved);
                    renderMatches();
                    renderRanking();
                } catch(e){}
            }
        }

        // initial
        function init() {
            loadFromLocal();
            renderMatches();
            renderRanking();

            toggleBtn.addEventListener('click', ()=>{
                adminPanel.classList.toggle('hidden');
                if(!adminPanel.classList.contains('hidden')) {
                    passwordOK = false;
                    adminStatus.textContent = 'Bitte Passwort eingeben';
                } else {
                    isAdmin = false;
                    passwordOK = false;
                }
                renderMatches();
            });

            verifyBtn.addEventListener('click', checkPassword);
            saveAllBtn.addEventListener('click', saveToLocal);
        }

        init();
    })();
</script>
</body>
</html>
